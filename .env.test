# Test Environment Configuration
# This file is used automatically by vitest.config.js

NODE_ENV=test
BYPASS_AUTH=true

# Database connection (tests use same DB as dev container)
# NOTE: Hardcoded credentials are intentional for local test environment only.
# This matches the ephemeral dev container configuration and is never used in production.
# The test database uses tmpfs storage and is destroyed on container restart.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=rotv
PGDATABASE=rotv
